# MyElectricalData Local Client - Environment Variables
# Copy this file to .env and fill in your values

# Gateway credentials (required)
CLIENT_ID=your_client_id
CLIENT_SECRET=your_client_secret
GATEWAY_URL=https://api.myelectricaldata.fr

# Database
DATABASE_URL=sqlite+aiosqlite:///data/myelectricaldata.db
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/myelectricaldata

# Synchronization
SYNC_INTERVAL=3600
SYNC_DAYS_BACK=7

# Home Assistant
HA_ENABLED=true
HA_DISCOVERY=true

# MQTT
MQTT_ENABLED=false
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=

# Metrics
METRICS_ENABLED=false
METRICS_PORT=9090

# Jeedom
JEEDOM_ENABLED=false
JEEDOM_URL=
JEEDOM_API_KEY=

# Logging
LOG_LEVEL=INFO
